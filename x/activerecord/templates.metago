{{- $isInsertable := and $isColumn (not $isAutomatic) }}
{{- if $isInsertable }}{{ $separator }}{{ $recv }}.{{ $fieldName }}{{ $separator = ", " }}{{ end }}
{{- end }} }
	},
	updateArgs: func({{ $recv }} *{{ $name }}) []any {
		return []any{

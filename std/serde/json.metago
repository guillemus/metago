        {{- $mapSliceBytes := false }}
        {{- $mapSlicePointerElemType := "" }}
        {{- $mapSlicePointerElemScalar := "" }}
        {{- $mapArrayElemType := "" }}
        {{- $mapArrayElemScalar := "" }}
        {{- $mapNestedKeyType := "" }}
        {{- $mapNestedElemType := "" }}
        {{- $mapNestedElemScalar := "" }}
        {{- $mapNestedPointerElemType := "" }}
        {{- $nativeStringMap := false }}
        {{- $mapParts := split $t "]" }}
        {{- if and (hasPrefix $t "map[") (ge (len $mapParts) 2) }}
            {{- $mapKeyType = trimPrefix (index $mapParts 0) "map[" }}
            {{- $mapPrefix := printf "map[%s]" $mapKeyType }}
            {{- $mapElemType = trimPrefix $t $mapPrefix }}
            {{- $mapElemScalar = $mapElemType }}
            {{- range $.Package.Types }}
                {{- if and (eq .Name $mapElemType) (not .Methods) }}{{ $mapElemScalar = .Underlying }}{{ end }}
            {{- end }}
            {{- if hasPrefix $mapElemType "*" }}
                {{- $mapPointerElemType = trimPrefix $mapElemType "*" }}
                {{- $mapPointerElemScalar = $mapPointerElemType }}
                {{- range $.Package.Types }}
                    {{- if and (eq .Name $mapPointerElemType) (not .Methods) }}{{ $mapPointerElemScalar = .Underlying }}{{ end }}
                {{- end }}
            {{- end }}
            {{- if hasPrefix $mapElemType "**" }}
                {{- $mapDoublePointerElemType = trimPrefix $mapElemType "**" }}
                {{- $mapDoublePointerElemScalar = $mapDoublePointerElemType }}
                {{- range $.Package.Types }}
                    {{- if and (eq .Name $mapDoublePointerElemType) (not .Methods) }}{{ $mapDoublePointerElemScalar = .Underlying }}{{ end }}
                {{- end }}
            {{- end }}
            {{- if hasPrefix $mapElemType "***" }}
                {{- $mapTriplePointerElemType = trimPrefix $mapElemType "***" }}
                {{- $mapTriplePointerElemScalar = $mapTriplePointerElemType }}
                {{- range $.Package.Types }}
                    {{- if and (eq .Name $mapTriplePointerElemType) (not .Methods) }}{{ $mapTriplePointerElemScalar = .Underlying }}{{ end }}
                {{- end }}
            {{- end }}
            {{- if hasPrefix $mapElemType "[]" }}
                {{- $mapSliceElemType = trimPrefix $mapElemType "[]" }}
                {{- $mapSliceBytes = eq $mapSliceElemType "byte" "uint8" }}
                {{- $mapSliceElemScalar = $mapSliceElemType }}
                {{- range $.Package.Types }}
                    {{- if and (eq .Name $mapSliceElemType) (not .Methods) }}{{ $mapSliceElemScalar = .Underlying }}{{ end }}
                {{- end }}
                {{- if eq $mapSliceElemScalar "byte" }}{{ $mapSliceElemScalar = "uint8" }}
                {{- else if eq $mapSliceElemScalar "rune" }}{{ $mapSliceElemScalar = "int32" }}
                {{- end }}
                {{- $mapSliceBytes = eq $mapSliceElemScalar "uint8" }}
                {{- if hasPrefix $mapSliceElemType "*" }}
                    {{- $mapSlicePointerElemType = trimPrefix $mapSliceElemType "*" }}
                    {{- $mapSlicePointerElemScalar = $mapSlicePointerElemType }}
                    {{- range $.Package.Types }}
                        {{- if and (eq .Name $mapSlicePointerElemType) (not .Methods) }}{{ $mapSlicePointerElemScalar = .Underlying }}{{ end }}
                    {{- end }}
                {{- end }}
            {{- else if hasPrefix $mapElemType "[" }}
                {{- $mapArrayParts := split $mapElemType "]" }}
                {{- if ge (len $mapArrayParts) 2 }}
                    {{- $mapArrayPrefix := printf "%s]" (index $mapArrayParts 0) }}
                    {{- $mapArrayElemType = trimPrefix $mapElemType $mapArrayPrefix }}
                    {{- $mapArrayElemScalar = $mapArrayElemType }}
                    {{- range $.Package.Types }}
                        {{- if and (eq .Name $mapArrayElemType) (not .Methods) }}{{ $mapArrayElemScalar = .Underlying }}{{ end }}
                    {{- end }}
                {{- end }}
            {{- else if hasPrefix $mapElemType "map[" }}
                {{- $nestedParts := split $mapElemType "]" }}
                {{- if ge (len $nestedParts) 2 }}
                    {{- $mapNestedKeyType = trimPrefix (index $nestedParts 0) "map[" }}
                    {{- $nestedPrefix := printf "map[%s]" $mapNestedKeyType }}
                    {{- $mapNestedElemType = trimPrefix $mapElemType $nestedPrefix }}
                    {{- $mapNestedElemScalar = $mapNestedElemType }}
                    {{- range $.Package.Types }}
                        {{- if and (eq .Name $mapNestedElemType) (not .Methods) }}{{ $mapNestedElemScalar = .Underlying }}{{ end }}
                    {{- end }}
                    {{- if hasPrefix $mapNestedElemType "*" }}{{ $mapNestedPointerElemType = trimPrefix $mapNestedElemType "*" }}{{ end }}
                {{- end }}
            {{- end }}
            {{- if contains $plainStringTypes (printf " %s " $mapKeyType) }}
                {{- if or (eq $mapElemScalar "string" "bool" "int" "int8" "int16" "int32" "int64" "uint" "uint8" "uint16" "uint32" "uint64" "float32" "float64") (eq $mapPointerElemScalar "string" "bool" "int" "int8" "int16" "int32" "int64" "uint" "uint8" "uint16" "uint32" "uint64" "float32" "float64") (eq $mapDoublePointerElemScalar "string" "bool" "int" "int8" "int16" "int32" "int64" "uint" "uint8" "uint16" "uint32" "uint64" "float32" "float64") (eq $mapTriplePointerElemScalar "string" "bool" "int" "int8" "int16" "int32" "int64" "uint" "uint8" "uint16" "uint32" "uint64" "float32" "float64") (eq $mapSliceElemScalar "string" "bool" "int" "int8" "int16" "int32" "int64" "uint" "uint8" "uint16" "uint32" "uint64" "float32" "float64") (eq $mapSlicePointerElemScalar "string" "bool" "int" "int8" "int16" "int32" "int64" "uint" "uint8" "uint16" "uint32" "uint64" "float32" "float64") (contains $jsonTypes (printf " %s " $mapSliceElemType)) (contains $jsonTypes (printf " %s " $mapSlicePointerElemType)) (eq $mapArrayElemScalar "string" "bool" "int" "int8" "int16" "int32" "int64" "uint" "uint8" "uint16" "uint32" "uint64" "float32" "float64") (contains $jsonTypes (printf " %s " $mapArrayElemType)) (and (contains $plainStringTypes (printf " %s " $mapNestedKeyType)) (or (eq $mapNestedElemScalar "string" "bool" "int" "int8" "int16" "int32" "int64" "uint" "uint8" "uint16" "uint32" "uint64" "float32" "float64") (contains $jsonTypes (printf " %s " $mapNestedElemType)) (contains $jsonTypes (printf " %s " $mapNestedPointerElemType)))) (eq $mapElemType "json.RawMessage" "encoding/json.RawMessage") (contains $jsonTypes (printf " %s " $mapElemType)) (contains $jsonTypes (printf " %s " $mapPointerElemType)) }}
                    {{- $nativeStringMap = true }}
                {{- end }}
            {{- end }}
        {{- end }}

        {{- /* Array shape analysis for generated fixed-array decoders. */}}
        {{- $arrayElemType := "" }}
        {{- $arrayElemScalar := "" }}
        {{- $nativeArray := false }}
        {{- $arrayParts := split $t "]" }}
        {{- if and (hasPrefix $t "[") (not (hasPrefix $t "[]")) (eq (len $arrayParts) 2) }}
            {{- $arrayElemType = index $arrayParts 1 }}
            {{- $arrayElemScalar = $arrayElemType }}
            {{- range $.Package.Types }}
                {{- if and (eq .Name $arrayElemType) (not .Methods) }}{{ $arrayElemScalar = .Underlying }}{{ end }}
            {{- end }}
            {{- if or (eq $arrayElemScalar "string" "bool" "int" "int8" "int16" "int32" "int64" "uint" "uint8" "uint16" "uint32" "uint64" "float32" "float64") (contains $jsonTypes (printf " %s " $arrayElemType)) }}
                {{- $nativeArray = true }}
            {{- end }}
        {{- end }}

        {{- /* Pointer shape analysis, currently bounded to three levels. */}}
        {{- $pointerElemType := "" }}
        {{- $pointerElemScalar := "" }}
        {{- $pointerScalar := false }}
        {{- $nestedPointerScalarType := "" }}
        {{- $nestedPointerScalar := "" }}
        {{- $triplePointerScalarType := "" }}
        {{- $triplePointerScalar := "" }}
        {{- if isPointer . }}
            {{- $pointerElemType = elem . }}
            {{- $pointerElemScalar = $pointerElemType }}
            {{- range $.Package.Types }}
                {{- if and (eq .Name $pointerElemType) (not .Methods) }}{{ $pointerElemScalar = .Underlying }}{{ end }}
            {{- end }}
            {{- if eq $pointerElemScalar "string" "bool" "int" "int8" "int16" "int32" "int64" "uint" "uint8" "uint16" "uint32" "uint64" "float32" "float64" }}
                {{- $pointerScalar = true }}
            {{- else if hasPrefix $pointerElemType "*" }}
                {{- $nestedElem := trimPrefix $pointerElemType "*" }}
                {{- $nestedPointerScalar = $nestedElem }}
                {{- range $.Package.Types }}
                    {{- if and (eq .Name $nestedElem) (not .Methods) }}{{ $nestedPointerScalar = .Underlying }}{{ end }}
                {{- end }}
                {{- if eq $nestedPointerScalar "string" "bool" "int" "int8" "int16" "int32" "int64" "uint" "uint8" "uint16" "uint32" "uint64" "float32" "float64" }}
                    {{- $nestedPointerScalarType = $nestedElem }}
                {{- else if hasPrefix $nestedElem "*" }}
                    {{- $tripleElem := trimPrefix $nestedElem "*" }}
                    {{- $triplePointerScalar = $tripleElem }}
                    {{- range $.Package.Types }}
                        {{- if and (eq .Name $tripleElem) (not .Methods) }}{{ $triplePointerScalar = .Underlying }}{{ end }}
                    {{- end }}
                    {{- if eq $triplePointerScalar "string" "bool" "int" "int8" "int16" "int32" "int64" "uint" "uint8" "uint16" "uint32" "uint64" "float32" "float64" }}
                        {{- $triplePointerScalarType = $tripleElem }}
                    {{- end }}
                {{- end }}
            {{- end }}
        {{- end }}
	jsonField{{ .Name }}:
		{
			valueOffset := l.Pos
        {{- if and $stringOption (eq $scalar "string" "bool" "int" "int8" "int16" "int32" "int64" "uint" "uint8" "uint16" "uint32" "uint64" "float32" "float64") }}
			if l.NotNull() {
        {{- if eq $scalar "string" }}
				if decoded, ok := l.QuotedString(); ok {
					v.{{ .Name }} = {{ $t }}(decoded)
				}
        {{- else if eq $scalar "bool" }}
				if decoded, ok := l.QuotedBool(); ok {
					v.{{ .Name }} = {{ $t }}(decoded)
				}
        {{- else if eq $scalar "int" "int8" "int16" "int32" "int64" }}
				if decoded, ok := l.QuotedInt({{ if eq $scalar "int" }}strconv.IntSize{{ else if eq $scalar "int8" }}8{{ else if eq $scalar "int16" }}16{{ else if eq $scalar "int32" }}32{{ else }}64{{ end }}); ok {
					v.{{ .Name }} = {{ $t }}(decoded)
				}
        {{- else if eq $scalar "uint" "uint8" "uint16" "uint32" "uint64" }}
				if decoded, ok := l.QuotedUint({{ if eq $scalar "uint" }}strconv.IntSize{{ else if eq $scalar "uint8" }}8{{ else if eq $scalar "uint16" }}16{{ else if eq $scalar "uint32" }}32{{ else }}64{{ end }}); ok {
					v.{{ .Name }} = {{ $t }}(decoded)
				}
        {{- else }}
				if decoded, ok := l.QuotedFloat({{ if eq $scalar "float32" }}32{{ else }}64{{ end }}); ok {
					v.{{ .Name }} = {{ $t }}(decoded)
				}
        {{- end }}
			}
        {{- else if eq $scalar "string" }}
			if l.NotNull() {
				v.{{ .Name }} = {{ $t }}(l.String())
			}
        {{- else if eq $scalar "bool" }}
			if l.NotNull() {
				v.{{ .Name }} = {{ $t }}(l.Bool())
			}
        {{- else if eq $scalar "int" "int8" "int16" "int32" "int64" }}
			if l.NotNull() {
				v.{{ .Name }} = {{ $t }}(l.Int({{ if eq $scalar "int" }}strconv.IntSize{{ else if eq $scalar "int8" }}8{{ else if eq $scalar "int16" }}16{{ else if eq $scalar "int32" }}32{{ else }}64{{ end }}))
			}
        {{- else if eq $scalar "uint" "uint8" "uint16" "uint32" "uint64" }}
			if l.NotNull() {
				v.{{ .Name }} = {{ $t }}(l.Uint({{ if eq $scalar "uint" }}strconv.IntSize{{ else if eq $scalar "uint8" }}8{{ else if eq $scalar "uint16" }}16{{ else if eq $scalar "uint32" }}32{{ else }}64{{ end }}))
			}
        {{- else if eq $scalar "float64" }}
			if l.NotNull() {
				v.{{ .Name }} = {{ $t }}(l.Float64())
			}
        {{- else if eq $scalar "float32" }}
			if l.NotNull() {
				v.{{ .Name }} = {{ $t }}(l.Float32())
			}
        {{- else if eq $t "[]byte" }}
			v.{{ .Name }} = l.Bytes()
        {{- else if eq $t "json.RawMessage" "encoding/json.RawMessage" }}
			raw := l.RawValue()
			if l.Err == nil {
				v.{{ .Name }} = append(v.{{ .Name }}[:0:0], raw...)
			}
        {{- else if $pointerScalar }}
			if l.IsNull() {
				v.{{ .Name }} = nil
			} else {
            {{- if eq $pointerElemScalar "string" }}
				decoded := {{ $pointerElemType }}(l.String())
            {{- else if eq $pointerElemScalar "bool" }}
				decoded := {{ $pointerElemType }}(l.Bool())
            {{- else if eq $pointerElemScalar "int" "int8" "int16" "int32" "int64" }}
				decoded := {{ $pointerElemType }}(l.Int({{ if eq $pointerElemScalar "int" }}strconv.IntSize{{ else if eq $pointerElemScalar "int8" }}8{{ else if eq $pointerElemScalar "int16" }}16{{ else if eq $pointerElemScalar "int32" }}32{{ else }}64{{ end }}))
            {{- else if eq $pointerElemScalar "uint" "uint8" "uint16" "uint32" "uint64" }}
				decoded := {{ $pointerElemType }}(l.Uint({{ if eq $pointerElemScalar "uint" }}strconv.IntSize{{ else if eq $pointerElemScalar "uint8" }}8{{ else if eq $pointerElemScalar "uint16" }}16{{ else if eq $pointerElemScalar "uint32" }}32{{ else }}64{{ end }}))
            {{- else if eq $pointerElemScalar "float32" }}
				decoded := {{ $pointerElemType }}(l.Float32())
            {{- else }}
				decoded := {{ $pointerElemType }}(l.Float64())
            {{- end }}
				if l.Err == nil {
					v.{{ .Name }} = &decoded
				}
			}
        {{- else if $nestedPointerScalarType }}
			if l.IsNull() {
				v.{{ .Name }} = nil
			} else {
            {{- if eq $nestedPointerScalar "string" }}
				decoded := {{ $nestedPointerScalarType }}(l.String())
            {{- else if eq $nestedPointerScalar "bool" }}
				decoded := {{ $nestedPointerScalarType }}(l.Bool())
            {{- else if eq $nestedPointerScalar "int" "int8" "int16" "int32" "int64" }}
				decoded := {{ $nestedPointerScalarType }}(l.Int({{ if eq $nestedPointerScalar "int" }}strconv.IntSize{{ else if eq $nestedPointerScalar "int8" }}8{{ else if eq $nestedPointerScalar "int16" }}16{{ else if eq $nestedPointerScalar "int32" }}32{{ else }}64{{ end }}))
            {{- else if eq $nestedPointerScalar "uint" "uint8" "uint16" "uint32" "uint64" }}
				decoded := {{ $nestedPointerScalarType }}(l.Uint({{ if eq $nestedPointerScalar "uint" }}strconv.IntSize{{ else if eq $nestedPointerScalar "uint8" }}8{{ else if eq $nestedPointerScalar "uint16" }}16{{ else if eq $nestedPointerScalar "uint32" }}32{{ else }}64{{ end }}))
            {{- else if eq $nestedPointerScalar "float32" }}
				decoded := {{ $nestedPointerScalarType }}(l.Float32())
            {{- else }}
				decoded := {{ $nestedPointerScalarType }}(l.Float64())
            {{- end }}
				if l.Err == nil {
					inner := &decoded
					v.{{ .Name }} = &inner
				}
			}
        {{- else if $triplePointerScalarType }}
			if l.IsNull() {
				v.{{ .Name }} = nil
			} else {
            {{- if eq $triplePointerScalar "string" }}
				decoded := {{ $triplePointerScalarType }}(l.String())
            {{- else if eq $triplePointerScalar "bool" }}
				decoded := {{ $triplePointerScalarType }}(l.Bool())
            {{- else if eq $triplePointerScalar "int" "int8" "int16" "int32" "int64" }}
				decoded := {{ $triplePointerScalarType }}(l.Int({{ if eq $triplePointerScalar "int" }}strconv.IntSize{{ else if eq $triplePointerScalar "int8" }}8{{ else if eq $triplePointerScalar "int16" }}16{{ else if eq $triplePointerScalar "int32" }}32{{ else }}64{{ end }}))
            {{- else if eq $triplePointerScalar "uint" "uint8" "uint16" "uint32" "uint64" }}
				decoded := {{ $triplePointerScalarType }}(l.Uint({{ if eq $triplePointerScalar "uint" }}strconv.IntSize{{ else if eq $triplePointerScalar "uint8" }}8{{ else if eq $triplePointerScalar "uint16" }}16{{ else if eq $triplePointerScalar "uint32" }}32{{ else }}64{{ end }}))
            {{- else if eq $triplePointerScalar "float32" }}
				decoded := {{ $triplePointerScalarType }}(l.Float32())
            {{- else }}
				decoded := {{ $triplePointerScalarType }}(l.Float64())
            {{- end }}
				if l.Err == nil {
					inner := &decoded
					middle := &inner
					v.{{ .Name }} = &middle
				}
			}
        {{- else if and (isPointer .) (contains $jsonTypes (printf " %s " (elem .))) }}
			if l.IsNull() {
				v.{{ .Name }} = nil
			} else {
				decoded := new({{ elem . }})
				if v.{{ .Name }} != nil {
					*decoded = *v.{{ .Name }}
				}
				decoded.unmarshalJSONLexer(l)
				if l.Err == nil {
					v.{{ .Name }} = decoded
				}
			}
        {{- else if contains $jsonTypes (printf " %s " $t) }}
			v.{{ .Name }}.unmarshalJSONLexer(l)
        {{- else if isPointer . }}
            {{- imports "encoding/json" }}
			if l.IsNull() {
				v.{{ .Name }} = nil
			} else {
				var decoded {{ elem . }}
            {{- if not (hasPrefix (elem .) "*") }}
				if v.{{ .Name }} != nil {
					decoded = *v.{{ .Name }}
				}
            {{- end }}
				raw := l.RawValue()
				if l.Err == nil {
					if err := json.Unmarshal(raw, &decoded); err != nil {
						l.Err = err
					} else {
						v.{{ .Name }} = &decoded
					}
				}
			}
        {{- else if isSlice . }}
            {{- $e := elem . }}
            {{- $eScalar := $e }}
            {{- $eFieldCount := 0 }}
            {{- range $.Package.Types }}
                {{- if eq .Name $e }}
                    {{- if not .Methods }}{{ $eScalar = .Underlying }}{{ end }}
                    {{- $eFieldCount = len .Fields }}
                {{- end }}
            {{- end }}
            {{- $stringSliceArena := eq $e "string" }}
            {{- $structSliceArena := and (contains $jsonTypes (printf " %s " $e)) (gt $eFieldCount 0) }}
            {{- /* Nested slabs use four slots per field and a schema-derived whole-input estimate. */}}
            {{- $pointerE := "" }}
            {{- $pointerEScalar := "" }}
            {{- $doublePointerE := "" }}
            {{- $doublePointerEScalar := "" }}
            {{- if hasPrefix $e "*" }}
                {{- $pointerE = trimPrefix $e "*" }}
                {{- $pointerEScalar = $pointerE }}
                {{- range $.Package.Types }}
                    {{- if and (eq .Name $pointerE) (not .Methods) }}{{ $pointerEScalar = .Underlying }}{{ end }}
                {{- end }}
                {{- if hasPrefix $pointerE "*" }}
                    {{- $doublePointerE = trimPrefix $pointerE "*" }}
                    {{- $doublePointerEScalar = $doublePointerE }}
                    {{- range $.Package.Types }}
                        {{- if and (eq .Name $doublePointerE) (not .Methods) }}{{ $doublePointerEScalar = .Underlying }}{{ end }}
                    {{- end }}
                {{- end }}
            {{- end }}
            {{- if eq $eScalar "uint8" }}
			decodedBytes := l.Bytes()
			if l.Err == nil {
				if decodedBytes == nil {
					v.{{ .Name }} = nil
				} else {
					v.{{ .Name }} = make([]{{ $e }}, len(decodedBytes))
					for i, element := range decodedBytes {
						v.{{ .Name }}[i] = {{ $e }}(element)
					}
				}
			}
            {{- else }}
			if l.IsNull() {
				v.{{ .Name }} = nil
			} else {
            {{- if $stringSliceArena }}
				if l.Depth > 1 {
					v.{{ .Name }} = l.state.valuesString.take(4, len(l.Data), 100)
				} else {
					v.{{ .Name }} = make([]{{ $e }}, 0, 4)
				}
            {{- else if $structSliceArena }}
				if l.Depth > 1 {
					v.{{ .Name }} = l.state.values{{ $e }}.take(4, len(l.Data), 28+{{ $eFieldCount }}*24)
				} else {
					capacity := 4
					planned := (len(l.Data) - l.Pos) / (64 + {{ $eFieldCount }}*32)
					capacity = max(capacity, planned)
					v.{{ .Name }} = make([]{{ $e }}, 0, capacity)
				}
            {{- else }}
				v.{{ .Name }} = make([]{{ $e }}, 0, 4)
            {{- end }}
				l.ArrayOpen()
				for f := true; l.MoreArray(f); f = false {
					if len(v.{{ .Name }}) == cap(v.{{ .Name }}) {
						grown := make([]{{ $e }}, len(v.{{ .Name }}), cap(v.{{ .Name }})*2)
						copy(grown, v.{{ .Name }})
						v.{{ .Name }} = grown
					}
            {{- if eq $eScalar "string" "bool" "int" "int8" "int16" "int32" "int64" "uint" "uint8" "uint16" "uint32" "uint64" "float32" "float64" }}
					if l.IsNull() {
						var zero {{ $e }}
						v.{{ .Name }} = append(v.{{ .Name }}, zero)
						continue
					}
            {{- end }}
            {{- if eq $eScalar "string" }}
					v.{{ .Name }} = append(v.{{ .Name }}, {{ $e }}(l.String()))
            {{- else if eq $eScalar "bool" }}
					v.{{ .Name }} = append(v.{{ .Name }}, {{ $e }}(l.Bool()))
            {{- else if eq $eScalar "int" "int8" "int16" "int32" "int64" }}
					v.{{ .Name }} = append(v.{{ .Name }}, {{ $e }}(l.Int({{ if eq $eScalar "int" }}strconv.IntSize{{ else if eq $eScalar "int8" }}8{{ else if eq $eScalar "int16" }}16{{ else if eq $eScalar "int32" }}32{{ else }}64{{ end }})))
            {{- else if eq $eScalar "uint" "uint8" "uint16" "uint32" "uint64" }}
					v.{{ .Name }} = append(v.{{ .Name }}, {{ $e }}(l.Uint({{ if eq $eScalar "uint" }}strconv.IntSize{{ else if eq $eScalar "uint8" }}8{{ else if eq $eScalar "uint16" }}16{{ else if eq $eScalar "uint32" }}32{{ else }}64{{ end }})))
            {{- else if eq $eScalar "float64" }}
					v.{{ .Name }} = append(v.{{ .Name }}, {{ $e }}(l.Float64()))
            {{- else if eq $eScalar "float32" }}
					v.{{ .Name }} = append(v.{{ .Name }}, {{ $e }}(l.Float32()))
            {{- else if eq $pointerEScalar "string" "bool" "int" "int8" "int16" "int32" "int64" "uint" "uint8" "uint16" "uint32" "uint64" "float32" "float64" }}
					if l.IsNull() {
						v.{{ .Name }} = append(v.{{ .Name }}, nil)
					} else {
                {{- if eq $pointerEScalar "string" }}
						decoded := {{ $pointerE }}(l.String())
                {{- else if eq $pointerEScalar "bool" }}
						decoded := {{ $pointerE }}(l.Bool())
                {{- else if eq $pointerEScalar "int" "int8" "int16" "int32" "int64" }}
						decoded := {{ $pointerE }}(l.Int({{ if eq $pointerEScalar "int" }}strconv.IntSize{{ else if eq $pointerEScalar "int8" }}8{{ else if eq $pointerEScalar "int16" }}16{{ else if eq $pointerEScalar "int32" }}32{{ else }}64{{ end }}))
                {{- else if eq $pointerEScalar "uint" "uint8" "uint16" "uint32" "uint64" }}
						decoded := {{ $pointerE }}(l.Uint({{ if eq $pointerEScalar "uint" }}strconv.IntSize{{ else if eq $pointerEScalar "uint8" }}8{{ else if eq $pointerEScalar "uint16" }}16{{ else if eq $pointerEScalar "uint32" }}32{{ else }}64{{ end }}))
                {{- else if eq $pointerEScalar "float32" }}
						decoded := {{ $pointerE }}(l.Float32())
                {{- else }}
						decoded := {{ $pointerE }}(l.Float64())
                {{- end }}
						if l.Err == nil {
							v.{{ .Name }} = append(v.{{ .Name }}, &decoded)

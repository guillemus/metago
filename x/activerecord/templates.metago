// ScanDestinations returns destinations in Columns order.
func (table {{ $name }}Table) ScanDestinations({{ $recv }} *{{ $name }}) []any {
	return []any{
{{- $separator := "" }}
{{- range $type.Fields }}
{{- $field := . }}
{{- $fieldName := name $field }}
{{- $isColumn := exported $fieldName }}
{{- if $isColumn }}{{ $separator }}&{{ $recv }}.{{ $fieldName }}{{ $separator = ", " }}{{ end }}
{{- end }} }
}

func (table {{ $name }}Table) ScanRow(row rowScanner, {{ $recv }} *{{ $name }}) error {
	return row.Scan(table.ScanDestinations({{ $recv }})...)
}

func (table {{ $name }}Table) ScanRows(rows *sql.Rows) ([]{{ $name }}, error) {
	records := make([]{{ $name }}, 0)
	for rows.Next() {
		var record {{ $name }}
		if err := table.ScanRow(rows, &record); err != nil { return nil, err }
		records = append(records, record)
	}
	return records, rows.Err()
}

func (table {{ $name }}Table) InsertArgs({{ $recv }} *{{ $name }}) []any {
	return {{ $prefix }}Model.insertArgs({{ $recv }})
}

// UpdateArgs returns non-primary values followed by the primary key.
func (table {{ $name }}Table) UpdateArgs({{ $recv }} *{{ $name }}) []any {
	return append({{ $prefix }}Model.updateArgs({{ $recv }}), {{ $prefix }}Model.primaryKey({{ $recv }}))
}

{{- end }}

          {{- $isPrimary := propHas $targetField "sql" "pk" }}
          {{- $isFilterable := and (propHas $targetField "sql" "filter") (not $isPrimary) }}
          {{- $isSortable := and (propHas $targetField "sql" "sort") (not $isPrimary) }}
          {{- $isPointer := isPointer $targetField }}
          {{- if $isFilterable }}
            {{- if $isPointer }}
              {{- $element := elem $targetField }}
              {{- $isText := isString $element }}
              {{- $isOrdered := or (isInt $element) (isFloat $element) }}
              {{- if $isText }}
	Where{{ $association }}{{ $targetFieldName }} nullableTextField[*{{ $name }}Query, {{ $element }}]
              {{- else if $isOrdered }}
	Where{{ $association }}{{ $targetFieldName }} nullableOrderedField[*{{ $name }}Query, {{ $element }}]
              {{- else }}
	Where{{ $association }}{{ $targetFieldName }} nullableField[*{{ $name }}Query, {{ $element }}]
              {{- end }}
            {{- else }}
              {{- $isText := isString $targetField }}
              {{- $isOrdered := or (isInt $targetField) (isFloat $targetField) (eq $targetFieldType "time.Time") }}
              {{- if $isText }}
	Where{{ $association }}{{ $targetFieldName }} textField[*{{ $name }}Query, {{ $targetFieldType }}]
              {{- else if $isOrdered }}
	Where{{ $association }}{{ $targetFieldName }} orderedField[*{{ $name }}Query, {{ $targetFieldType }}]
              {{- else }}
	Where{{ $association }}{{ $targetFieldName }} equalField[*{{ $name }}Query, {{ $targetFieldType }}]

{{/*
  Type-safe SQL model and query glue.

  Generate once per package:
    //mgo:gen queries

  Mark models and field capabilities:
    //mgo:model table=users
    type User struct {
        ID    int64  //mgo:sql pk auto filter sort
        Email string //mgo:sql unique filter
        Name  string //mgo:sql sort
    }

  Every exported field is a column and may use any database/sql-compatible or
  Scanner/Valuer type. The optional sql prop configures flags pk, auto, unique,
  filter, sort and the column=... argument.
*/}}

{{ define "queries" }}
{{ template "queries-runtime" . }}

{{- range .Package.Types }}
{{- $candidate := . }}
{{- $isModel := propExists $candidate "model" }}
{{- if $isModel }}
{{- $type := $candidate }}
{{- $name := name $type }}
{{- $recv := receiver $type }}
{{- $prefix := unexported $name }}
{{- $defaultTable := printf "%ss" (snake $name) }}
{{- $configuredTable := prop $type "model" "table" }}
{{- $table := default $defaultTable $configuredTable }}
{{- $defaultEntry := pascal $table }}
{{- $configuredEntry := prop $type "model" "handle" }}
{{- $entry := default $defaultEntry $configuredEntry }}
{{- $pkName := "" }}
{{- $pkType := "" }}
{{- $pkCol := "" }}
{{- $auto := false }}
{{- range $type.Fields }}
{{- $field := . }}
{{- $fieldName := name $field }}
{{- $fieldType := typeof $field }}
{{- $isTime := eq $fieldType "time.Time" }}
{{- $isSQLType := hasPrefix $fieldType "sql." }}
{{- if $isTime }}{{ imports "time" }}{{ end }}
{{- if $isSQLType }}{{ imports "database/sql" }}{{ end }}
{{- $isExported := exported $fieldName }}
{{- $isColumn := $isExported }}
{{- $isPrimaryKey := propHas $field "sql" "pk" }}
{{- if and $isColumn $isPrimaryKey }}
{{- $defaultColumnName := snake $fieldName }}
{{- $configuredColumnName := prop $field "sql" "column" }}
{{- $pkName = $fieldName }}
{{- $pkType = $fieldType }}
{{- $pkCol = default $defaultColumnName $configuredColumnName }}
{{- $auto = propHas $field "sql" "auto" }}
{{- end }}
{{- end }}

// ---------------------------------------------------------------------------
// {{ $name }} (table {{ $table }})
// ---------------------------------------------------------------------------

// {{ $name }}Columns contains generated column names. Table metadata lives
// separately so model fields named Name, Columns, or UpdateSet cannot collide.
type {{ $name }}Columns struct {
{{- range $type.Fields }}
{{- $field := . }}
{{- $fieldName := name $field }}
{{- $isExported := exported $fieldName }}
{{- $isColumn := $isExported }}
{{- if $isColumn }}
	{{ $fieldName }} Column[{{ typeof $field }}]
{{- end }}
{{- end }}
}

type {{ $name }}Table struct {
	Name               string
	Col                {{ $name }}Columns
	Columns            string
	InsertColumns      string
	InsertPlaceholders string
	UpdateSet          string
}

// Qualified returns a copy whose columns are prefixed with the table name.
// The package-level Tables value is immutable and remains unqualified.
func (t {{ $name }}Table) Qualified() {{ $name }}Table {
{{- range $type.Fields }}
{{- $field := . }}
{{- $fieldName := name $field }}
{{- $isExported := exported $fieldName }}
{{- $isColumn := $isExported }}
{{- if $isColumn }}
	if !strings.HasPrefix(string(t.Col.{{ $fieldName }}), t.Name+".") {
		t.Col.{{ $fieldName }} = Column[{{ typeof $field }}](t.Name + "." + string(t.Col.{{ $fieldName }}))
	}
{{- end }}
{{- end }}
	t.Columns = "
{{- $separator := "" }}
{{- range $type.Fields }}
{{- $field := . }}
{{- $fieldName := name $field }}
{{- $isExported := exported $fieldName }}
{{- $isColumn := $isExported }}
{{- if $isColumn }}
{{- $separator }}" + string(t.Col.{{ $fieldName }}) + "
{{- $separator = ", " }}
{{- end }}
{{- end }}"
	return t
}

var {{ $prefix }}Table = {{ $name }}Table{
	Name: {{ quote $table }},
	Col: {{ $name }}Columns{
{{- range $type.Fields }}
{{- $field := . }}
{{- $fieldName := name $field }}
{{- $isExported := exported $fieldName }}
{{- $isColumn := $isExported }}
{{- $defaultColumnName := snake $fieldName }}
{{- $configuredColumnName := prop $field "sql" "column" }}
{{- $columnName := default $defaultColumnName $configuredColumnName }}
{{- if $isColumn }}
		{{ $fieldName }}: {{ quote $columnName }},
{{- end }}
{{- end }}
	},
	Columns: "
{{- $separator := "" }}
{{- range $type.Fields }}
{{- $field := . }}
{{- $fieldName := name $field }}
{{- $isColumn := exported $fieldName }}
{{- $columnName := default (snake $fieldName) (prop $field "sql" "column") }}
{{- if $isColumn }}{{ $separator }}{{ $columnName }}{{ $separator = ", " }}{{ end }}
{{- end }}",
	InsertColumns: "
{{- $separator := "" }}
{{- range $type.Fields }}
{{- $field := . }}
{{- $fieldName := name $field }}
{{- $isColumn := exported $fieldName }}
{{- $isAutomatic := propHas $field "sql" "auto" }}
{{- $isInsertable := and $isColumn (not $isAutomatic) }}
{{- $columnName := default (snake $fieldName) (prop $field "sql" "column") }}
{{- if $isInsertable }}{{ $separator }}{{ $columnName }}{{ $separator = ", " }}{{ end }}
{{- end }}",
	InsertPlaceholders: "
{{- $separator := "" }}
{{- range $type.Fields }}
{{- $field := . }}
{{- $fieldName := name $field }}
{{- $isColumn := exported $fieldName }}
{{- $isAutomatic := propHas $field "sql" "auto" }}
{{- $isInsertable := and $isColumn (not $isAutomatic) }}
{{- if $isInsertable }}{{ $separator }}?{{ $separator = ", " }}{{ end }}
{{- end }}",
	UpdateSet: "
{{- $separator := "" }}
{{- range $type.Fields }}
{{- $field := . }}
{{- $fieldName := name $field }}
{{- $isColumn := exported $fieldName }}
{{- $isPrimaryKey := propHas $field "sql" "pk" }}
{{- $isUpdatable := and $isColumn (not $isPrimaryKey) }}
{{- $columnName := default (snake $fieldName) (prop $field "sql" "column") }}
{{- if $isUpdatable }}{{ $separator }}{{ $columnName }} = ?{{ $separator = ", " }}{{ end }}
{{- end }}",
}

const {{ $prefix }}SelectColumns = "
{{- $separator := "" }}
{{- range $type.Fields }}
{{- $field := . }}
{{- $fieldName := name $field }}
{{- $isColumn := exported $fieldName }}
{{- $columnName := default (snake $fieldName) (prop $field "sql" "column") }}
{{- if $isColumn }}{{ $separator }}{{ $columnName }}{{ $separator = ", " }}{{ end }}
{{- end }}"

var {{ $prefix }}Model = modelSpec[{{ $name }}, {{ $pkType }}]{
	name:          {{ quote $name }},
	handle:        {{ quote $entry }},
	table:         {{ quote $table }},
	columns:       {{ $prefix }}SelectColumns,

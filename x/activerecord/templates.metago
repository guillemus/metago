type {{ $name }}Query struct {
	*query[{{ $name }}, {{ $pkType }}, *{{ $name }}Query]
{{- range $type.Fields }}
{{- $field := . }}
{{- $fieldName := name $field }}
{{- $fieldType := typeof $field }}
{{- $isColumn := exported $fieldName }}
{{- $isFilterable := and $isColumn (propHas $field "sql" "filter") }}

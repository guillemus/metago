{{ define "stringer" }}
func (x {{ name . }}) String() string {
    {{ if eq (typeof .) "string" -}}
    return string(x)
    {{ else if eq (typeof .) "int" -}}
    {{ imports "strconv" -}}
    return strconv.Itoa(int(x))
    {{ else -}}
    return `{{ name . }}({{ typeof . }})`
    {{ end -}}
}
{{ end }}

{{ define "enum" }}
func {{ name . }}Values() []{{ name . }} {
    return []{{ name . }}{ {{ range .Values }}{{ .Name }}, {{ end }} }
}
{{ end }}

{{ define "fields" }}
func (x {{ name . }}) FieldNames() []string {
    return []string{ {{ range keys . }}{{ printf "%q" . }}, {{ end }} }
}
{{ end }}

{{ define "summary" }}
func {{ name . }}MetaSummary() string {
    return {{ quote (printf "%s|%s|%s|fields=%s|id_json=%s|id_has_json=%t|id_omitempty=%t|methods=%s" .Kind (typeof .) .Args.table (join (keys .) ",") (tag (index .Fields 0) "json") (tagExists (index .Fields 0) "json") (tagHas (index .Fields 0) "json" "omitempty") (methodNames .)) }}
}
{{ end }}

{{- else }}
	Where{{ $fieldName }} nullableField[*{{ $name }}Query, {{ $element }}]
{{- end }}
{{- else }}
{{- $isText := isString $field }}
{{- $isOrdered := or (isInt $field) (isFloat $field) (eq $fieldType "time.Time") }}
{{- if $isText }}
	Where{{ $fieldName }} textField[*{{ $name }}Query, {{ $fieldType }}]
{{- else if $isOrdered }}
	Where{{ $fieldName }} orderedField[*{{ $name }}Query, {{ $fieldType }}]
{{- else }}
	Where{{ $fieldName }} equalField[*{{ $name }}Query, {{ $fieldType }}]
{{- end }}
{{- end }}
{{- end }}
{{- if $isSortable }}
	OrderBy{{ $fieldName }} orderField[*{{ $name }}Query]
{{- end }}
{{- end }}
{{- range $type.Fields }}
  {{- $relationField := . }}
  {{- $relationFieldName := name $relationField }}
  {{- $association := trimSuffix $relationFieldName "ID" }}
  {{- $targetName := prop $relationField "relation" "belongsTo" }}
  {{- if $targetName }}
    {{- range $.Package.Types }}
      {{- $target := . }}
      {{- $isTarget := eq (name $target) $targetName }}
      {{- $isModel := propExists $target "model" }}
      {{- $isRelatedModel := and $isTarget $isModel }}
      {{- if $isRelatedModel }}
        {{- range $target.Fields }}
          {{- $targetField := . }}
          {{- $targetFieldName := name $targetField }}

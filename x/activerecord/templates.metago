{{- $element := elem $field }}
{{- $isText := isString $element }}
{{- $isOrdered := or (isInt $element) (isFloat $element) }}
{{- if $isText }}
	Where{{ $fieldName }} nullableTextField[*{{ $name }}Query, {{ $element }}]
{{- else if $isOrdered }}

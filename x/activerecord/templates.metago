// Tables contains static schema metadata for hand-written SQL. Column names are
// unqualified by default; call Qualified when composing joins.
var Tables = struct {
{{- range .Package.Types }}
{{- if propExists . "model" }}
{{- $table := default (printf "%ss" (snake (name .))) (prop . "model" "table") }}
{{- $entry := default (pascal $table) (prop . "model" "handle") }}
	{{ $entry }} {{ name . }}Table
{{- end }}
{{- end }}
}{
{{- range .Package.Types }}
{{- if propExists . "model" }}
{{- $table := default (printf "%ss" (snake (name .))) (prop . "model" "table") }}
{{- $entry := default (pascal $table) (prop . "model" "handle") }}
	{{ $entry }}: {{ unexported (name .) }}Table,
{{- end }}
{{- end }}
}

// Models groups the package's query handles under one database scope.
// It is safe to reuse when its DBTX implementation supports concurrent use.
type Models struct {
{{- range .Package.Types }}
{{- if propExists . "model" }}
{{- $table := default (printf "%ss" (snake (name .))) (prop . "model" "table") }}
{{- $entry := default (pascal $table) (prop . "model" "handle") }}
	{{ $entry }} *{{ name . }}Query
{{- end }}
{{- end }}
}

func NewModels(db DBTX) *Models {
	return &Models{
{{- range .Package.Types }}
{{- if propExists . "model" }}
{{- $table := default (printf "%ss" (snake (name .))) (prop . "model" "table") }}
{{- $entry := default (pascal $table) (prop . "model" "handle") }}
		{{ $entry }}: {{ $entry }}(db),
{{- end }}
{{- end }}
	}
}

// With returns the same set of query handles scoped to another connection or transaction.
func (m *Models) With(db DBTX) *Models { return NewModels(db) }

{{ end }}

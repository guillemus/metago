						l.Err = err
					} else {
						v.{{ .Name }} = decoded
					}
				}
			}
        {{- else if eq $t "any" "interface{}" }}
            {{- imports "encoding/json" }}
			var decoded {{ $t }}
			raw := l.RawValue()
			if l.Err == nil {
				if err := json.Unmarshal(raw, &decoded); err != nil {
					l.Err = err
				} else {
					v.{{ .Name }} = decoded
				}
			}
        {{- else if contains $methodTypes (printf " %s " $t) }}
            {{- imports "encoding/json" }}
			var decoded {{ $t }}
			raw := l.RawValue()
			if l.Err == nil {
				if err := json.Unmarshal(raw, &decoded); err != nil {
					l.Err = err
				} else {
					v.{{ .Name }} = decoded
				}
			}
        {{- else }}
            {{- imports "encoding/json" }}
			raw := l.RawValue()
			if l.Err == nil {
				if err := json.Unmarshal(raw, &v.{{ .Name }}); err != nil {
					l.Err = err
				}
			}
        {{- end }}
			if l.Err != nil {
				l.WrapField({{ quote $key }}, {{ quote $t }}, valueOffset)
			}
			continue
		}
    {{- end }}
{{- end }}
	}
	l.LeaveValue()
{{- end }}
}
{{ end }}

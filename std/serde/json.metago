// UnmarshalJSON implements json.Unmarshaler for {{ $typeName }}.
func (v *{{ $typeName }}) UnmarshalJSON(data []byte) error {
	{{- if $maxInputArg }}
	if maxInput := uint64({{ $maxInputArg }}); maxInput > 0 && uint64(len(data)) > maxInput {
		return fmt.Errorf("json: {{ $typeName }}: input size %d exceeds maximum %d", len(data), maxInput)
	}
	{{- end }}
	next := *v
{{- if embeddedFields . }}
    {{- range .Fields }}
        {{- if and .Embedded (isPointer .) }}
	if next.{{ .Name }} != nil {
		cloned{{ .Name }} := *next.{{ .Name }}
		next.{{ .Name }} = &cloned{{ .Name }}
	}
        {{- end }}
    {{- end }}
{{- end }}
	baseLexer := {{ $lexerType }}{Data: data{{ with $maxDepthArg }}, MaxDepth: uint64({{ . }}){{ end }}}
	l := {{ $decodeLexerType }}{Lexer: baseLexer}
	l.EnableStringArena(len(data) * 3 / 8)
	next.unmarshalJSONLexer(&l)
	if l.Err != nil {
		return fmt.Errorf("json: {{ $typeName }}: %w", l.Err)
	}
	l.SkipWS()
	if l.Pos < len(l.Data) {
		return fmt.Errorf("json: trailing data at offset %d", l.Pos)
	}
	*v = next
	return nil
}


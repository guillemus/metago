{{ define "stringer" }}
func (x {{ name . }}) String() string {
{{ if eq (typeof .) "string" -}}
    return string(x)
{{ else if eq (typeof .) "int" -}}
    {{ imports "strconv" -}}
    return strconv.Itoa(int(x))
{{ else -}}
    return `{{ name . }}({{ typeof . }})`
{{ end -}}
}
{{ end }}

{{ define "enum" }}
func {{ name . }}Values() []{{ name . }} {
    return []{{ name . }}{ {{ range .Values }}{{ .Name }}, {{ end }} }
}
{{ end }}

{{ define "fields" }}
func (x {{ name . }}) FieldNames() []string {
    return []string{ {{ range keys . }}{{ printf "%q" . }}, {{ end }} }
}
{{ end }}

{{ define "summary" }}
{{- $kind := .Kind }}
{{- $type := typeof . }}
{{- $table := .Args.table }}
{{- $fields := join (keys .) "," }}
{{- $idField := index .Fields 0 }}
{{- $idJSON := tag $idField "json" }}
{{- $idHasJSON := tagExists $idField "json" }}
{{- $idOmitempty := tagHas $idField "json" "omitempty" }}
{{- $methods := methodNames . }}
{{- $summary := printf
    "%s|%s|%s|fields=%s|id_json=%s|id_has_json=%t|id_omitempty=%t|methods=%s"
    $kind
    $type
    $table
    $fields
    $idJSON
    $idHasJSON
    $idOmitempty
    $methods
}}
func {{ name . }}MetaSummary() string {
    return {{ quote $summary }}
}
{{ end }}

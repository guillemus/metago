          {{- end }}
        {{- end }}
      {{- end }}
    {{- end }}
  {{- end }}
{{- end }}
}

func {{ $entry }}(db DBTX) *{{ $name }}Query { return new{{ $name }}Query(db, newQueryState()) }

// And combines this query's predicates with another {{ $name }} query.
// Execution settings from the receiver are preserved.
func (q *{{ $name }}Query) And(other *{{ $name }}Query) *{{ $name }}Query {
	if other == nil { return q }
	return q.combine("AND", other.query)
}

// Or combines this query's predicates with another {{ $name }} query.
// Execution settings from the receiver are preserved.
func (q *{{ $name }}Query) Or(other *{{ $name }}Query) *{{ $name }}Query {
	if other == nil { return q }
	return q.combine("OR", other.query)
}

